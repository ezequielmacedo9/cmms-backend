# =============================================================================
# CMMS Backend — Environment variables template
# Copy this file to `.env` (or set the variables in your shell / cloud provider)
# and never commit the real `.env` file.
# =============================================================================

# -----------------------------------------------------------------------------
# JWT — REQUIRED in every environment.
# Minimum 32 bytes (256 bits) for HS256. Generate with:
#   openssl rand -base64 48
# -----------------------------------------------------------------------------
JWT_SECRET=replace-me-with-a-strong-secret-at-least-32-bytes-long
# Optional. Defaults to 86400000 ms (24h). For tighter security use 900000 (15min).
JWT_EXPIRATION=86400000

# -----------------------------------------------------------------------------
# Database — REQUIRED in prod profile (PostgreSQL).
# In dev (default profile) the in-memory H2 is used and these are ignored.
# -----------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/cmms
SPRING_DATASOURCE_USERNAME=cmms
SPRING_DATASOURCE_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Bootstrap admin — REQUIRED in prod when the database is empty.
# If absent, the application starts normally but no default user is created.
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Mail (SMTP) — optional. Required only for password reset / invitation flows.
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Application URLs and integrations
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:4200
SELF_URL=http://localhost:8080
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Server (mostly for prod profile)
# -----------------------------------------------------------------------------
PORT=8080
